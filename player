function playSong(url, name) {
  const audio = document.getElementById("audio");
  const trackName = document.getElementById("trackName");

  audio.src = url;
  trackName.textContent = name;
  audio.play();
}

function togglePlay() {
  const audio = document.getElementById("audio");
  if (audio.paused) {
    audio.play();
  } else {
    audio.pause();
  }
}
